{
  "$defs": {
    "TranscriptSegment": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        },
        "end_seconds": {
          "exclusiveMinimum": 0.0,
          "title": "End Seconds",
          "type": "number"
        },
        "segment_id": {
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._:-]+$",
          "title": "Segment Id",
          "type": "string"
        },
        "start_seconds": {
          "minimum": 0.0,
          "title": "Start Seconds",
          "type": "number"
        },
        "text": {
          "minLength": 1,
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "segment_id",
        "start_seconds",
        "end_seconds",
        "text"
      ],
      "title": "TranscriptSegment",
      "type": "object"
    }
  },
  "$id": "transcription_result.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "doc_id": {
      "minLength": 1,
      "title": "Doc Id",
      "type": "string"
    },
    "language": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Language"
    },
    "media_id": {
      "minLength": 1,
      "title": "Media Id",
      "type": "string"
    },
    "metadata": {
      "title": "Metadata",
      "type": "object"
    },
    "model_name": {
      "minLength": 1,
      "title": "Model Name",
      "type": "string"
    },
    "provider": {
      "const": "modal",
      "default": "modal",
      "title": "Provider",
      "type": "string"
    },
    "runtime": {
      "const": "serverless_gpu",
      "default": "serverless_gpu",
      "title": "Runtime",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "segments": {
      "items": {
        "$ref": "#/$defs/TranscriptSegment"
      },
      "title": "Segments",
      "type": "array"
    },
    "transcript_text": {
      "minLength": 1,
      "title": "Transcript Text",
      "type": "string"
    }
  },
  "required": [
    "doc_id",
    "media_id",
    "model_name",
    "transcript_text"
  ],
  "title": "TranscriptionResult",
  "type": "object"
}
