{
  "$defs": {
    "TOCSection": {
      "additionalProperties": false,
      "properties": {
        "children": {
          "items": {
            "$ref": "#/$defs/TOCSection"
          },
          "title": "Children",
          "type": "array"
        },
        "chunk_ids": {
          "items": {
            "type": "string"
          },
          "title": "Chunk Ids",
          "type": "array"
        },
        "key_terms": {
          "items": {
            "type": "string"
          },
          "title": "Key Terms",
          "type": "array"
        },
        "order": {
          "minimum": 0,
          "title": "Order",
          "type": "integer"
        },
        "section_id": {
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._:-]+$",
          "title": "Section Id",
          "type": "string"
        },
        "source_anchor": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Anchor"
        },
        "summary": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Summary"
        },
        "title": {
          "minLength": 1,
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "section_id",
        "title",
        "order"
      ],
      "title": "TOCSection",
      "type": "object"
    }
  },
  "$id": "toc.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "doc_id": {
      "minLength": 1,
      "title": "Doc Id",
      "type": "string"
    },
    "generated_at": {
      "format": "date-time",
      "title": "Generated At",
      "type": "string"
    },
    "metadata": {
      "title": "Metadata",
      "type": "object"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "sections": {
      "items": {
        "$ref": "#/$defs/TOCSection"
      },
      "title": "Sections",
      "type": "array"
    }
  },
  "required": [
    "doc_id"
  ],
  "title": "TOCData",
  "type": "object"
}
