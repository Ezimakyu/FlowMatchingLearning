{
  "$defs": {
    "ConceptEdgeEvidence": {
      "additionalProperties": false,
      "properties": {
        "current_chunk_ids": {
          "items": {
            "type": "string"
          },
          "title": "Current Chunk Ids",
          "type": "array"
        },
        "current_doc_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Current Doc Id"
        },
        "historical_chunk_ids": {
          "items": {
            "type": "string"
          },
          "title": "Historical Chunk Ids",
          "type": "array"
        },
        "historical_doc_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Historical Doc Id"
        }
      },
      "title": "ConceptEdgeEvidence",
      "type": "object"
    },
    "LLMCallMetadata": {
      "additionalProperties": false,
      "properties": {
        "max_tokens": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Tokens"
        },
        "model": {
          "minLength": 1,
          "title": "Model",
          "type": "string"
        },
        "prompt_name": {
          "minLength": 1,
          "title": "Prompt Name",
          "type": "string"
        },
        "prompt_version": {
          "minLength": 1,
          "title": "Prompt Version",
          "type": "string"
        },
        "provider": {
          "const": "openai",
          "default": "openai",
          "title": "Provider",
          "type": "string"
        },
        "request_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Request Id"
        },
        "temperature": {
          "anyOf": [
            {
              "maximum": 2.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Temperature"
        }
      },
      "required": [
        "prompt_name",
        "prompt_version",
        "model"
      ],
      "title": "LLMCallMetadata",
      "type": "object"
    },
    "SectionConcept": {
      "additionalProperties": false,
      "properties": {
        "aliases": {
          "items": {
            "type": "string"
          },
          "title": "Aliases",
          "type": "array"
        },
        "concept_id": {
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._:-]+$",
          "title": "Concept Id",
          "type": "string"
        },
        "confidence": {
          "default": 1.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "evidence_text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidence Text"
        },
        "historical_matches": {
          "items": {
            "$ref": "#/$defs/SimilarityMatch"
          },
          "title": "Historical Matches",
          "type": "array"
        },
        "label": {
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "source_chunk_ids": {
          "items": {
            "type": "string"
          },
          "title": "Source Chunk Ids",
          "type": "array"
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "concept_id",
        "label",
        "summary"
      ],
      "title": "SectionConcept",
      "type": "object"
    },
    "SectionEdgeCandidate": {
      "additionalProperties": false,
      "properties": {
        "accepted": {
          "default": true,
          "title": "Accepted",
          "type": "boolean"
        },
        "confidence": {
          "default": 1.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "evidence": {
          "$ref": "#/$defs/ConceptEdgeEvidence"
        },
        "explanation": {
          "minLength": 1,
          "title": "Explanation",
          "type": "string"
        },
        "relation": {
          "const": "prerequisite_for",
          "default": "prerequisite_for",
          "title": "Relation",
          "type": "string"
        },
        "source_concept_id": {
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._:-]+$",
          "title": "Source Concept Id",
          "type": "string"
        },
        "target_concept_id": {
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._:-]+$",
          "title": "Target Concept Id",
          "type": "string"
        }
      },
      "required": [
        "source_concept_id",
        "target_concept_id",
        "explanation"
      ],
      "title": "SectionEdgeCandidate",
      "type": "object"
    },
    "SectionResultStatus": {
      "enum": [
        "ok",
        "partial",
        "failed"
      ],
      "title": "SectionResultStatus",
      "type": "string"
    },
    "SimilarityMatch": {
      "additionalProperties": false,
      "properties": {
        "historical_chunk_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Historical Chunk Id"
        },
        "historical_concept_id": {
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._:-]+$",
          "title": "Historical Concept Id",
          "type": "string"
        },
        "historical_doc_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Historical Doc Id"
        },
        "historical_section_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Historical Section Id"
        },
        "retrieval_provider": {
          "const": "actian",
          "default": "actian",
          "title": "Retrieval Provider",
          "type": "string"
        },
        "similarity": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Similarity",
          "type": "number"
        }
      },
      "required": [
        "historical_concept_id",
        "similarity"
      ],
      "title": "SimilarityMatch",
      "type": "object"
    }
  },
  "$id": "section_parse_result.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "concepts": {
      "items": {
        "$ref": "#/$defs/SectionConcept"
      },
      "title": "Concepts",
      "type": "array"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "doc_id": {
      "minLength": 1,
      "title": "Doc Id",
      "type": "string"
    },
    "edge_candidates": {
      "items": {
        "$ref": "#/$defs/SectionEdgeCandidate"
      },
      "title": "Edge Candidates",
      "type": "array"
    },
    "errors": {
      "items": {
        "type": "string"
      },
      "title": "Errors",
      "type": "array"
    },
    "job_id": {
      "minLength": 1,
      "title": "Job Id",
      "type": "string"
    },
    "llm_calls": {
      "items": {
        "$ref": "#/$defs/LLMCallMetadata"
      },
      "title": "Llm Calls",
      "type": "array"
    },
    "metadata": {
      "title": "Metadata",
      "type": "object"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "section_id": {
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "title": "Section Id",
      "type": "string"
    },
    "section_order": {
      "minimum": 0,
      "title": "Section Order",
      "type": "integer"
    },
    "section_title": {
      "minLength": 1,
      "title": "Section Title",
      "type": "string"
    },
    "source_chunk_ids": {
      "items": {
        "type": "string"
      },
      "title": "Source Chunk Ids",
      "type": "array"
    },
    "status": {
      "$ref": "#/$defs/SectionResultStatus",
      "default": "ok"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "job_id",
    "doc_id",
    "section_id",
    "section_order",
    "section_title"
  ],
  "title": "SectionParseResult",
  "type": "object"
}
