{
  "$defs": {
    "ConceptEdge": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "default": 1.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "evidence": {
          "$ref": "#/$defs/ConceptEdgeEvidence"
        },
        "explanation": {
          "minLength": 1,
          "title": "Explanation",
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._:-]+$",
          "title": "Id",
          "type": "string"
        },
        "metadata": {
          "title": "Metadata",
          "type": "object"
        },
        "relation": {
          "const": "prerequisite_for",
          "default": "prerequisite_for",
          "title": "Relation",
          "type": "string"
        },
        "source": {
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._:-]+$",
          "title": "Source",
          "type": "string"
        },
        "target": {
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._:-]+$",
          "title": "Target",
          "type": "string"
        }
      },
      "required": [
        "id",
        "source",
        "target",
        "explanation"
      ],
      "title": "ConceptEdge",
      "type": "object"
    },
    "ConceptEdgeEvidence": {
      "additionalProperties": false,
      "properties": {
        "current_chunk_ids": {
          "items": {
            "type": "string"
          },
          "title": "Current Chunk Ids",
          "type": "array"
        },
        "current_doc_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Current Doc Id"
        },
        "historical_chunk_ids": {
          "items": {
            "type": "string"
          },
          "title": "Historical Chunk Ids",
          "type": "array"
        },
        "historical_doc_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Historical Doc Id"
        }
      },
      "title": "ConceptEdgeEvidence",
      "type": "object"
    },
    "ConceptNode": {
      "additionalProperties": false,
      "properties": {
        "aliases": {
          "items": {
            "type": "string"
          },
          "title": "Aliases",
          "type": "array"
        },
        "confidence": {
          "default": 1.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "deep_dive": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Deep Dive"
        },
        "id": {
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._:-]+$",
          "title": "Id",
          "type": "string"
        },
        "label": {
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "metadata": {
          "title": "Metadata",
          "type": "object"
        },
        "source_material": {
          "$ref": "#/$defs/SourceMaterial"
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "id",
        "label",
        "summary",
        "source_material"
      ],
      "title": "ConceptNode",
      "type": "object"
    },
    "SourceMaterial": {
      "additionalProperties": false,
      "properties": {
        "chunk_ids": {
          "items": {
            "type": "string"
          },
          "title": "Chunk Ids",
          "type": "array"
        },
        "doc_id": {
          "minLength": 1,
          "title": "Doc Id",
          "type": "string"
        },
        "page_numbers": {
          "items": {
            "type": "integer"
          },
          "title": "Page Numbers",
          "type": "array"
        },
        "section_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Section Id"
        },
        "snippet": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Snippet"
        },
        "transcript_timestamps": {
          "items": {
            "type": "string"
          },
          "title": "Transcript Timestamps",
          "type": "array"
        }
      },
      "required": [
        "doc_id"
      ],
      "title": "SourceMaterial",
      "type": "object"
    }
  },
  "$id": "graph_data.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "edges": {
      "items": {
        "$ref": "#/$defs/ConceptEdge"
      },
      "title": "Edges",
      "type": "array"
    },
    "generated_at": {
      "format": "date-time",
      "title": "Generated At",
      "type": "string"
    },
    "graph_id": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Graph Id"
    },
    "metadata": {
      "title": "Metadata",
      "type": "object"
    },
    "nodes": {
      "items": {
        "$ref": "#/$defs/ConceptNode"
      },
      "title": "Nodes",
      "type": "array"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "title": "GraphData",
  "type": "object"
}
