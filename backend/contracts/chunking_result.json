{
  "$defs": {
    "RawTextChunk": {
      "additionalProperties": false,
      "properties": {
        "chunk_id": {
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._:-]+$",
          "title": "Chunk Id",
          "type": "string"
        },
        "doc_id": {
          "minLength": 1,
          "title": "Doc Id",
          "type": "string"
        },
        "metadata": {
          "title": "Metadata",
          "type": "object"
        },
        "order": {
          "minimum": 0,
          "title": "Order",
          "type": "integer"
        },
        "section_hint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Section Hint"
        },
        "source_page": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Page"
        },
        "source_time_end_seconds": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Time End Seconds"
        },
        "source_time_start_seconds": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Time Start Seconds"
        },
        "source_type": {
          "default": "manual",
          "enum": [
            "transcript",
            "vision_text",
            "vision_image_description",
            "manual"
          ],
          "title": "Source Type",
          "type": "string"
        },
        "text": {
          "minLength": 1,
          "title": "Text",
          "type": "string"
        },
        "token_estimate": {
          "minimum": 1,
          "title": "Token Estimate",
          "type": "integer"
        }
      },
      "required": [
        "chunk_id",
        "doc_id",
        "order",
        "text",
        "token_estimate"
      ],
      "title": "RawTextChunk",
      "type": "object"
    }
  },
  "$id": "chunking_result.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "chunks": {
      "items": {
        "$ref": "#/$defs/RawTextChunk"
      },
      "title": "Chunks",
      "type": "array"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "doc_id": {
      "minLength": 1,
      "title": "Doc Id",
      "type": "string"
    },
    "metadata": {
      "title": "Metadata",
      "type": "object"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "doc_id"
  ],
  "title": "ChunkingResult",
  "type": "object"
}
